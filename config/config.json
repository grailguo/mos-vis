{
  "agent": {
    "asr_listen_timeout_ms": 15000,
    "enable_metrics": true
  },
  "asr": {
    "backend": "sherpa-onnx",
    "language": "zh-en",
    "model_path": "models/sherpa-onnx-rk3588-streaming-zipformer-bilingual-zh-en-2023-02-20",
    "partial_interval_ms": 200
  },
  "audio": {
    "audio_channels": 1,
    "input_device": "AIUI-USB-MC",
    "output_device": "rockchip-es8388",
    "sample_rate_hz": 16000
  },
  "control": {
    "retry_count": 1,
    "timeout_ms": 1500,
    "url": "ws://127.0.0.1:9001/api"
  },
  "kws": {
    "backend": "sherpa-onnx",
    "model_path": "models/sherpa-onnx-kws-zipformer-zh-en-3M-2025-12-20",
    "pre_roll_ms": 600,
    "trigger_threshold": 0.7
  },
  "logging": {
    "level": "debug",
    "structured": true
  },
  "nlu": {
    "critical_confirmation_required": true
  },
  "rag": {
    "cache_ttl_s": 60,
    "enabled": true,
    "index_path": "data/rag/index.bin",
    "max_context_tokens": 1200,
    "request_timeout_ms": 800,
    "score_threshold": 0.35,
    "top_k": 4
  },
  "ring_buffer": {
    "frame_capacity": 32768,
    "sample_capacity": 32768
  },
  "tts": {
    "backend": "sherpa-onnx",
    "barge_in_mode": "vad-only",
    "model_path": "models/vits-melo-tts-zh_en",
    "speed": 1
  },
  "vad": {
    "backend": "rknn",
    "enable_barge_in": true,
    "min_silence_ms": 300,
    "min_speech_ms": 180,
    "model_path": "models/silero-vad-v4-rk3588.rknn",
    "threshold": 0.55
  },
  "wake_ack_text": [
    {
      "keywords": [
        "0801"
      ],
      "preset_file": "",
      "reply_text": "收到，请说。"
    },
    {
      "keywords": [
        "0803"
      ],
      "preset_file": "",
      "reply_text": "我在，请指示。"
    },
    {
      "keywords": [
        "小G"
      ],
      "preset_file": "",
      "reply_text": "在呢，请继续。"
    },
    {
      "keywords": [
        "小莫"
      ],
      "preset_file": "",
      "reply_text": "我在，请讲。"
    }
  ]
}